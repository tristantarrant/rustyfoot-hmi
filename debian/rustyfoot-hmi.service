[Unit]
Description=Rustyfoot HMI
After=network.target rustyfoot.service
Wants=rustyfoot.service

[Service]
Type=simple
User=modhost
Environment=MOD_DATA_DIR=/var/lib/rustyfoot
Environment=MOD_USER_FILES_DIR=/var/lib/rustyfoot/user-files
ExecStart=/usr/bin/rustyfoot-hmi
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
